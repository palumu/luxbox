{
  "name": "@palumu/luxbox",
  "version": "1.0.0",
  "description": "A premium, minimalist React image gallery and lightbox.",
  "main": "./dist/Luxbox.js",
  "module": "./dist/Luxbox.mjs",
  "types": "./dist/Luxbox.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/Luxbox.tsx --format esm,cjs --dts --external react,react-dom,lucide-react",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "react",
    "lightbox",
    "gallery",
    "carousel"
  ],
  "author": "Songwut Satien",
  "license": "MIT",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "lucide-react": "^0.470.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
